      "uses": ["applescript"]
    },
    "shape.add": {
      "script": "shape.add.applescript",
      "args": [
        { "name": "kind",   "from": "--kind",   "required": true },
        { "name": "left",   "from": "--left",   "default": "0" },
        { "name": "top",    "from": "--top",    "default": "0" },
        { "name": "width",  "from": "--width",  "default": "0" },
        { "name": "height", "from": "--height", "default": "0" },
        { "name": "text",   "from": "--text",   "default": "" }
      ],
      "uses": ["applescript"]
    }
  }
}
