{
  "$schema": "https://yome.work/schema/yome-skill.json",
  "slug": "@yome/xl",
  "name": "Excel",
  "description": "Excel 工作簿全功能命令（基础读写 + 排序/筛选/冻结/图表/透视表/条件格式/数据验证/批注/链接/打印/页面设置 等）",
  "domain": "xl",
  "version": "1.1.0",
  "official": true,
  "homepage": "https://yome.work/skills/@yome/xl",
  "repo": "https://github.com/Whopus/yome-skill-xl",
  "yome_min_version": "1.0.0",
  "platforms": ["macos", "ios", "linux", "node", "sandbox"],
  "delivery": {
    "macos": {
      "backend": "bundled",
      "min_app_version": "1.0.0",
      "implements_signature": ">=1.0.0 <2.0.0"
    },
    "ios": {
      "backend": "bundled",
      "min_app_version": "1.0.0",
      "implements_signature": ">=1.0.0 <2.0.0"
    },
    "node": {
      "backend": "ota",
      "package": "backends/node",
      "entry": "src/index.ts",
      "implements_signature": ">=1.0.0 <2.0.0"
    },
    "python": {
      "backend": "ota",
      "package": "backends/python",
      "entry": "xl_backend.py",
      "runtime": "python>=3.10",
      "engine": "openpyxl",
      "implements_signature": ">=1.0.0 <2.0.0"
    },
    "sandbox": {
      "backend": "ota",
      "package": "backends/sandbox",
      "entry": "src/index.ts",
      "implements_signature": ">=1.0.0 <2.0.0"
    }
  },
  "backends": {
    "applescript-excel": {
      "runtime": "applescript",
      "engine": "Microsoft Excel",
      "platforms": ["macos"],
      "supports": ["*"]
    },
    "python-openpyxl": {
      "runtime": "python",
      "engine": "openpyxl",
      "platforms": ["linux", "macos", "windows"],
      "supports": [
        "info", "open", "new", "save", "close", "books",
        "sheets", "sheet", "sheet.add", "sheet.rename", "sheet.delete",
        "used", "get", "range", "find",
        "set", "fill", "clear", "fmt", "width",
        "row.add", "row.delete", "col.add", "col.delete",
        "merge", "unmerge", "export"
      ]
    },
    "node-ota": {
      "runtime": "node",
      "platforms": ["linux", "macos", "windows"],
      "status": "stub",
      "supports": []
    },
    "sandbox-memory": {
      "runtime": "node",
      "platforms": ["sandbox"],
      "supports": ["*"]
    }
  },
  "adapters": {
    "linux": {
      "prefer": ["python-openpyxl"]
    },
    "macos": {
      "prefer": ["applescript-excel", "python-openpyxl"]
    },
    "windows": {
      "prefer": ["python-openpyxl"]
    },
    "sandbox": {
      "prefer": ["sandbox-memory"]
    }
  },
  "ota_overlay": {
    "signature_version": "1.0.0",
    "viewer_version": "1.0.0",
    "data_version": "1.0.0"
  },
  "capabilities": ["fs:read", "fs:write", "applescript"],
  "system_capabilities": ["fs:read", "fs:write", "applescript"],
  "permissions_summary": {
    "zh": "读写 .xlsx/.xls 文件；macOS 可调用 Microsoft Excel，Linux/Windows 可用 python-openpyxl 后端读写 .xlsx/.xlsm",
    "en": "Read/write .xlsx/.xls files; macOS can control Microsoft Excel, Linux/Windows can use the python-openpyxl backend for .xlsx/.xlsm"
  },
  "l1": {
    "when": "user wants to read / edit / format / export an Excel workbook (.xlsx, .xls)",
    "entry": "xl --help",
    "effects": "opens or modifies a workbook; writes .xlsx / .csv to disk on headless Python hosts, and .xlsx / .pdf / .csv through Microsoft Excel on macOS"
  },
  "tags": ["productivity", "office", "spreadsheet"],
  "license": "Apache-2.0",
  "author": {
    "name": "Yome Official",
    "github": "Whopus"
  },
  "commands": [
    { "action": "info",         "desc": "返回工作簿概览（sheet、行列、已用范围）" },
    { "action": "open",         "desc": "打开已有 .xlsx/.xls 文件" },
    { "action": "new",          "desc": "新建空白工作簿" },
    { "action": "save",         "desc": "保存当前工作簿（可另存为）" },
    { "action": "close",        "desc": "关闭当前工作簿" },
    { "action": "books",        "desc": "列出已打开的工作簿" },
    { "action": "sheets",       "desc": "列出当前工作簿的所有工作表" },
    { "action": "sheet",        "desc": "切换活动工作表" },
    { "action": "sheet.add",    "desc": "新建工作表" },
    { "action": "sheet.rename", "desc": "重命名工作表" },
    { "action": "sheet.delete", "desc": "删除工作表" },
    { "action": "get",          "desc": "读取单个单元格" },
    { "action": "range",        "desc": "读取一片范围（TSV）" },
    { "action": "used",         "desc": "返回活动表已用范围与行列数" },
    { "action": "find",         "desc": "搜索关键词" },
    { "action": "set",          "desc": "写入单元格值或公式" },
    { "action": "fill",         "desc": "批量填充范围（TSV）" },
    { "action": "clear",        "desc": "清除范围内容" },
    { "action": "fmt",          "desc": "格式化单元格（粗体/字号/颜色/背景/对齐/数字格式/边框）" },
    { "action": "width",        "desc": "设置列宽" },
    { "action": "row.add",      "desc": "插入行" },
    { "action": "row.delete",   "desc": "删除行" },
    { "action": "col.add",      "desc": "插入列" },
    { "action": "col.delete",   "desc": "删除列" },
    { "action": "merge",        "desc": "合并单元格" },
    { "action": "unmerge",      "desc": "取消合并" },
    { "action": "export",       "desc": "导出为 PDF / CSV" },

    { "action": "sort",            "desc": "排序范围（最多 3 键）" },
    { "action": "filter",          "desc": "自动筛选（可指定 field/criteria）" },
    { "action": "filter.clear",    "desc": "清除所有筛选" },
    { "action": "freeze",          "desc": "冻结窗格 (--row --col)" },
    { "action": "freeze.clear",    "desc": "取消冻结" },
    { "action": "autofit",         "desc": "自动调整行高/列宽" },
    { "action": "copy",            "desc": "复制范围到剪贴板" },
    { "action": "cut",             "desc": "剪切范围到剪贴板" },
    { "action": "paste",           "desc": "粘贴到目标 (--what 控制 values/formulas/formats…)" },
    { "action": "page",            "desc": "页面设置（方向/纸张/缩放/页眉页脚/页边距）" },
    { "action": "printarea",       "desc": "设置打印区域" },
    { "action": "print",           "desc": "打印工作表/工作簿" },

    { "action": "chart.add",       "desc": "新建图表对象（column/bar/line/pie/area/scatter）" },
    { "action": "chart.delete",    "desc": "删除图表对象" },
    { "action": "chart.export",    "desc": "导出图表为 PNG/JPG" },
    { "action": "image.add",       "desc": "插入图片" },

    { "action": "pivot.add",       "desc": "新建透视表" },
    { "action": "pivot.refresh",   "desc": "刷新透视表" },
    { "action": "pivot.field",     "desc": "设置透视字段（row/column/page/data + sum/avg/...）" },

    { "action": "cf",              "desc": "条件格式（cellvalue/colorscale/databar/iconset）" },
    { "action": "validation",      "desc": "数据验证（list/number/date/text）" },
    { "action": "comment",         "desc": "添加单元格批注" },
    { "action": "comment.delete",  "desc": "删除批注" },
    { "action": "link",            "desc": "添加超链接" },
    { "action": "name",            "desc": "命名范围（增/删）" },

    { "action": "sheet.copy",      "desc": "复制工作表" },
    { "action": "sheet.move",      "desc": "移动工作表" },
    { "action": "sheet.hide",      "desc": "隐藏工作表 (hidden/very-hidden/visible)" },
    { "action": "sheet.protect",   "desc": "保护工作表" },
    { "action": "sheet.unprotect", "desc": "取消保护" },
    { "action": "sheet.color",     "desc": "设置工作表标签颜色" },

    { "action": "height",          "desc": "设置行高" },
    { "action": "row.hide",        "desc": "隐藏/显示行" },
    { "action": "col.hide",        "desc": "隐藏/显示列" },
    { "action": "insert",          "desc": "插入单元格 (--shift=down|right)" },
    { "action": "delete",          "desc": "删除单元格 (--shift=up|left)" },
    { "action": "autofill",        "desc": "自动填充 (default/copy/series/formats/values)" },

    { "action": "zoom",            "desc": "视图缩放 (10..400)" },
    { "action": "view",            "desc": "视图模式 (normal|page-break|page-layout)" },
    { "action": "gridlines",       "desc": "显示/隐藏网格线" },
    { "action": "headings",        "desc": "显示/隐藏行列标题" },
    { "action": "group",           "desc": "分组行/列" },
    { "action": "ungroup",         "desc": "取消分组" },
    { "action": "wrap",            "desc": "自动换行" },
    { "action": "rotate",          "desc": "文本旋转 (-90..90)" },
    { "action": "indent",          "desc": "缩进级别 (0..15)" },

    { "action": "recalc",          "desc": "强制重算 (workbook|sheet|app)" },
    { "action": "protect.book",    "desc": "保护工作簿（结构/窗口）" },
    { "action": "props",           "desc": "读/写文档属性 (title/author/subject/keywords/comments)" },
    { "action": "screen",          "desc": "屏幕刷新 on/off（批量加速）" },
    { "action": "alerts",          "desc": "弹窗提示 on/off（静默模式）" },
    { "action": "undo",            "desc": "撤销" },
    { "action": "shape.add",       "desc": "插入形状（rectangle/oval/line/arrow/text）" }
  ]
}
